{
  "name": "My Care Lab",
  "short_name": "My Care Lab",
  "start_url": "app.html",
  "scope": "./",
  "display": "fullscreen",
  "display_override": ["fullscreen", "standalone", "minimal-ui"],
  "orientation": "portrait",
